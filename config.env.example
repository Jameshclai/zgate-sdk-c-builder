# Copy to config.env and adjust as needed (config.env is gitignored if you add it)

# vcpkg root (required for ci-linux-x64 preset)
export VCPKG_ROOT="${VCPKG_ROOT:-/home/user/vcpkg}"

# Working directory for downloads (ziti-sdk-c, tlsuv)
export WORK_DIR="${WORK_DIR:-$(cd "$(dirname "$0")" && pwd)/work}"

# Where to put output zgate-sdk-c-xx.xx.xx (parent directory; default: project's output/ subdir)
export OUTPUT_DIR="${OUTPUT_DIR:-$(cd "$(dirname "$0")" && pwd)/output}"

# Optional: pin versions instead of latest
# export ZITI_SDK_TAG="v1.11.1"
# export TLSUV_TAG="v0.40.12"
